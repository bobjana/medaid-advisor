package cc.zynafin.medaid.config

#QZ|import org.springframework.ai.ollama.OllamaEmbeddingModel
#BR|import org.springframework.context.annotation.Bean
#XX|import org.springframework.context.annotation.Configuration
#PK|import org.springframework.context.annotation.Primary
#BT|
/**
 * Configuration for Spring AI embedding models.
 *
 * We use Ollama for embeddings and OpenAI-compatible mode for chat.
 * This configuration marks OllamaEmbeddingModel as @Primary to avoid ambiguity.
 */
@Configuration
open class EmbeddingModelConfig(
    private val ollamaEmbeddingModel: OllamaEmbeddingModel
) {

    @Bean
    @Primary
    fun embeddingModel(): OllamaEmbeddingModel {
        return ollamaEmbeddingModel
    }
}
